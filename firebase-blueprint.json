{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Private and public user data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "exporterName": { "type": "string" },
        "tin": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Shipment": {
      "title": "Shipment",
      "description": "Logistics and compliance data for a shipment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "externalId": { "type": "string" },
        "origin": { "type": "string" },
        "destination": { "type": "string" },
        "totalValue": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["Cleared", "Under Review", "High Risk"] },
        "riskScore": { "type": "number" },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exporter": { "type": "string" },
        "importer": { "type": "string" },
        "hsCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "externalId", "origin", "destination", "createdAt", "updatedAt"]
    },
    "ComplianceAlert": {
      "title": "Compliance Alert",
      "description": "Flags raised by the AI engine",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shipmentId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["Critical", "Warning", "Audit"] },
        "message": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["shipmentId", "userId", "type", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/shipments/{shipmentId}": {
      "schema": "Shipment",
      "description": "Collection of all shipments"
    },
    "/compliance_alerts/{alertId}": {
      "schema": "ComplianceAlert",
      "description": "Risk and compliance alerts"
    }
  }
}
